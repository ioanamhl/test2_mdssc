// ============================================================
// MDSSC Pipeline — Jenkinsfile (plugin-based)
//
// Stages:
//   1. Checkout           — clone repo + info build
//   2. Check Health       — verifică conexiunea la serverul MDSSC
//   3. MDSSC Source Scan  — scanare cod sursă via plugin Jenkins
//   4. Security Scan      — npm audit + ESLint
//   5. Build              — build proiect (Backend + frontend)
//   6. MDSSC Artifact Scan— scanare artefact build via plugin Jenkins
//   7. Deploy             — deploy (dezactivat implicit)
//
// Necesită în Jenkins UI:
//   - Credențial "key" (Secret Text) cu MDSSC API key
//   - Variabila de mediu MDSSC_INSTANCE_URL (Manage Jenkins → System)
//   - Plugin MDSSC Scanner instalat
// ============================================================

String mdssc_apiBaseUrl(String server) {
    String s = server.replaceAll('/+$', '')
    if (s.endsWith('/api/v1')) return s
    if (s.endsWith('/api'))   return "${s}/v1"
    return "${s}/api/v1"
}

void mdssc_checkHealth(String server, String credId = 'key', String header = 'apikey') {
    String baseUrl = mdssc_apiBaseUrl(server)

    withCredentials([string(credentialsId: credId, variable: 'MDSSC_API_KEY')]) {
        sh """
            set -eu
            echo "=========================================="
            echo "MDSSC Health Check — ${server}"
            echo "=========================================="

            check_endpoint() {
                local path="\$1"
                local desc="\$2"
                code=\$(curl -sS -w '%{http_code}' -o .mdssc-hc.json \\
                    --max-time 15 \\
                    -H "${header}: \$MDSSC_API_KEY" \\
                    "${baseUrl}\$path" 2>/dev/null) || code=0
                echo "GET \$path -> HTTP \$code (\$desc)"
                if [ "\$code" -ge 200 ] && [ "\$code" -lt 300 ]; then
                    cat .mdssc-hc.json 2>/dev/null && echo ""
                    return 0
                fi
                return 1
            }

            check_endpoint "/health"        "health endpoint"           && exit 0 || true
            check_endpoint "/version"       "version endpoint"          && exit 0 || true
            check_endpoint "/scans?limit=1" "scans list (connectivity)" && exit 0 || true

            echo "WARNING: Could not confirm MDSSC server health. Continuing pipeline."
        """
    }
}

pipeline {
    agent any

    options {
        skipDefaultCheckout(false)
        buildDiscarder(logRotator(numToKeepStr: '20'))
        timeout(time: 30, unit: 'MINUTES')
    }

    parameters {
        choice(name: 'STACK',
               choices: ['node', 'python', 'java', 'go', 'custom'],
               description: 'Stack-ul proiectului.')
        string(name: 'BUILD_COMMAND',
               defaultValue: '',
               description: 'Comandă de build custom. Gol = default per stack.')
        booleanParam(name: 'RUN_DEPLOY',
                     defaultValue: false,
                     description: 'Activează stage-ul Deploy.')
        string(name: 'DEPLOY_METHOD',
               defaultValue: 'none',
               description: 'pm2 | docker | systemd | none')
    }

    environment {
        ARTIFACT_DIR   = 'artifacts'
        MDSSC_INSTANCE = 'http://35.156.106.42/'
        MDSSC_WF_ID    = '6a27260e006f2db36a982671'
        PATH           = "/usr/local/bin:/usr/bin:/bin:${env.PATH}"
    }

    stages {

        // ----------------------------------------------------------
        // 1. CHECKOUT
        // ----------------------------------------------------------
        stage('Checkout') {
            steps {
                checkout scm

                sh '''
                    echo "=== Build Info ==="
                    echo "Branch : $(git rev-parse --abbrev-ref HEAD 2>/dev/null || echo N/A)"
                    echo "Commit : $(git rev-parse --short HEAD 2>/dev/null || echo N/A)"
                    echo "=== Tool Versions ==="
                    node --version   2>/dev/null || echo "node: not found"
                    npm  --version   2>/dev/null || echo "npm: not found"
                    docker --version 2>/dev/null || echo "docker: not found"
                '''

                sh 'rm -rf "$ARTIFACT_DIR" && mkdir -p "$ARTIFACT_DIR"'
            }
        }

        // ----------------------------------------------------------
        // 2. CHECK HEALTH
        // ----------------------------------------------------------
        stage('Check Health') {
            steps {
                script {
                    def server = env.MDSSC_INSTANCE_URL?.trim() ?: env.MDSSC_INSTANCE
                    mdssc_checkHealth(server)
                }
            }
        }

        // ----------------------------------------------------------
        // 3. MDSSC SOURCE CODE SCAN
        // ----------------------------------------------------------
        stage('MDSSC Source Scan') {
            steps {
                step([$class: 'SourceCodeScanStep',
                    mdsscInstance:          env.MDSSC_INSTANCE,
                    credentialsId:          'key',
                    workflowId:             env.MDSSC_WF_ID,
                    branch:                 'main',
                    vulnerabilityThreshold: 'none',
                    failOnSecret:           false,
                    failOnMalware:          true,
                    scanTimeout:            900,
                    pollInterval:           10
                ])
            }
        }

        // ----------------------------------------------------------
        // 4. BUILD
        // ----------------------------------------------------------
        stage('Build') {
            steps {
                script {
                    echo "=== Build (stack: ${params.STACK}) ==="
                    def cmd = params.BUILD_COMMAND?.trim()

                    if (params.STACK == 'node') {
                        def hasBackend  = fileExists('Backend/package.json')
                        def hasFrontend = fileExists('frontend/package.json')

                        if (hasBackend || hasFrontend) {
                            def tasks = [:]
                            if (hasBackend) {
                                tasks['Backend — npm ci'] = {
                                    dir('Backend') { sh 'npm ci' }
                                }
                            }
                            if (hasFrontend) {
                                tasks['Frontend — npm ci + build'] = {
                                    dir('frontend') {
                                        sh 'npm ci'
                                        sh cmd ?: 'npm run build'
                                    }
                                }
                            }
                            parallel tasks
                        } else {
                            sh 'npm ci'
                            if (cmd) sh cmd
                        }
                    } else if (params.STACK == 'python') {
                        sh 'pip install -r requirements.txt'
                        if (cmd) sh cmd
                    } else if (params.STACK == 'java') {
                        sh cmd ?: 'mvn package -DskipTests'
                    } else if (params.STACK == 'go') {
                        sh cmd ?: 'go build ./...'
                    } else {
                        if (cmd) sh cmd
                        else echo "Stack '${params.STACK}': nicio comandă de build definită."
                    }

                    // Împachetează frontend dist pentru artifact scan
                    sh '''
                        if [ -d frontend/dist ]; then
                            tar -czf "$ARTIFACT_DIR/frontend-dist.tar.gz" -C frontend/dist .
                            echo "Packaged frontend/dist → $ARTIFACT_DIR/frontend-dist.tar.gz"
                        fi
                    '''

                    archiveArtifacts artifacts: "${ARTIFACT_DIR}/**", allowEmptyArchive: true, fingerprint: true
                }
            }
        }

        // ----------------------------------------------------------
        // 6. MDSSC ARTIFACT SCAN
        // ----------------------------------------------------------
        stage('MDSSC Artifact Scan') {
            when {
                expression { return fileExists("${ARTIFACT_DIR}/frontend-dist.tar.gz") }
            }
            steps {
                step([$class: 'ArtifactScanStep',
                    mdsscInstance:          env.MDSSC_INSTANCE,
                    credentialsId:          'key',
                    filePath:               "${ARTIFACT_DIR}/frontend-dist.tar.gz",
                    workflowId:             env.MDSSC_WF_ID,
                    vulnerabilityThreshold: 'none',
                    failOnSecret:           false,
                    failOnMalware:          true,
                    scanTimeout:            900,
                    pollInterval:           10,
                    maxFileSizeMb:          100
                ])
            }
        }

        // ----------------------------------------------------------
        // 7. DEPLOY
        // ----------------------------------------------------------
        stage('Deploy') {
            when {
                expression { return params.RUN_DEPLOY && params.DEPLOY_METHOD != 'none' }
            }
            steps {
                script {
                    echo "=== Deploy (method: ${params.DEPLOY_METHOD}) ==="
                    if (params.DEPLOY_METHOD == 'docker') {
                        sh 'docker compose up -d --build'
                    } else if (params.DEPLOY_METHOD == 'pm2') {
                        sh 'pm2 restart all || pm2 start npm --name app -- start'
                    } else if (params.DEPLOY_METHOD == 'systemd') {
                        sh 'systemctl restart app'
                    } else {
                        echo "DEPLOY_METHOD necunoscut: ${params.DEPLOY_METHOD}"
                    }
                }
            }
        }
    }

    post {
        success { echo "Pipeline completat cu succes." }
        failure { echo "Pipeline eșuat — verifică console log." }
        always  { sh 'rm -f .mdssc-* 2>/dev/null || true' }
    }
}
